# Mongo connection (mirrors what cassavaBE uses)
MONGO_URI=mongodb://112.137.129.218:27017
MONGO_DB=iot_agriculture

# Default group + sensor for this MVP (single weather station, temperature only)
GROUP_ID=69e35b13e405c05c3dab13c9
SENSOR_ID=temperature

# Anomaly threshold: |z_score| > ANOMALY_K → anomaly
ANOMALY_K=3.0

# Resample frequency for ML training (hourly mean — matches NASA POWER hourly grid)
RESAMPLE_FREQ=1h

# API port (loopback only in prod; FE/BE call via this)
API_PORT=8082
